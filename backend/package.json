{
  "name": "memora-backend",
  "version": "1.0.0",
  "description": "Backend API for Memora",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --forceExit --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --watch --forceExit --detectOpenHandles",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --forceExit --detectOpenHandles",
    "test:auth": "cross-env NODE_ENV=test jest tests/controllers/auth.test.js --forceExit --detectOpenHandles",
    "test:notes": "cross-env NODE_ENV=test jest tests/controllers/note.test.js --forceExit",
    "test:categories": "cross-env NODE_ENV=test jest tests/controllers/category.test.js --forceExit",
    "test:middleware": "cross-env NODE_ENV=test jest tests/middleware/ --forceExit"
  },
  "keywords": [
    "notes",
    "management",
    "api",
    "express",
    "mongodb"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.0",
    "node-mocks-http": "^1.18.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
