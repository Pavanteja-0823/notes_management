# ─── Server Configuration ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────
# Replace with your MongoDB connection string
# Local: mongodb://localhost:27017/smart-notes
# Atlas: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/smart-notes
MONGODB_URI=mongodb://localhost:27017/smart-notes

# ─── JWT ─────────────────────────────────────────────────────────
# Generate a random secret key (e.g., using `openssl rand -base64 32`)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── Frontend ────────────────────────────────────────────────────
# Used for CORS configuration
FRONTEND_URL=http://localhost:5173

# ─── AI Provider ─────────────────────────────────────────────────
# Supported: groq, openai, gemini, claude, deepseek, ollama
AI_PROVIDER=groq

# Groq (default) - Get key at https://console.groq.com
# Format: gsk_...
GROQ_API_KEY=your-groq-api-key-here

# OpenAI - Get key at https://platform.openai.com
# OPENAI_API_KEY=sk-...

# AI Model (Groq options: llama3-70b-8192, llama3-8b-8192, mixtral-8x7b-32768, gemma2-9b-it)
AI_MODEL=llama3-70b-8192
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
