# ─── Server Configuration ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────
# Replace with your MongoDB connection string
# Local: mongodb://localhost:27017/smart-notes
# Atlas: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/smart-notes
MONGODB_URI=mongodb://localhost:27017/smart-notes

# ─── JWT Authentication ─────────────────────────────────────────
# Generate a random secret key (e.g., using `openssl rand -base64 32`)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── JWT Refresh Tokens ──────────────────────────────────────────
# Separate secret for refresh tokens (more secure)
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production
# Refresh token expiry in milliseconds (default: 30 days)
REFRESH_TOKEN_EXPIRES_MS=2592000000

# ─── Rate Limiting ───────────────────────────────────────────────
# General API rate limit: requests per 15 min window per IP
RATE_LIMIT_MAX=100
# Auth routes: login/register attempts per 15 min window per IP
AUTH_RATE_LIMIT_MAX=10
# AI features: requests per 1 min window per IP
AI_RATE_LIMIT_MAX=30
# File uploads: uploads per 1 min window per IP
UPLOAD_RATE_LIMIT_MAX=5

# ─── Frontend ────────────────────────────────────────────────────
# Used for CORS configuration
FRONTEND_URL=http://localhost:5173

# ─── AI Provider ─────────────────────────────────────────────────
# Supported: groq, openai, gemini, claude, deepseek, ollama
AI_PROVIDER=groq

# Groq (default) - Get key at https://console.groq.com
# Format: gsk_...
GROQ_API_KEY=your-groq-api-key-here

# OpenAI - Get key at https://platform.openai.com
# OPENAI_API_KEY=sk-...

# AI Model (Groq options: llama3-70b-8192, llama3-8b-8192, mixtral-8x7b-32768, gemma2-9b-it)
AI_MODEL=llama3-70b-8192
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ─── Test Configuration ─────────────────────────────────────────
# MongoDB in-memory server settings (for tests)
MONGODB_MEMORY_PORT=27018
# Test database name
TEST_DB_NAME=smart-notes-test
